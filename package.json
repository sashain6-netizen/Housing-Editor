{
  "name": "hypixel-housing-htsl-editor",
  "version": "1.0.0",
  "description": "Visual Node Editor for Hypixel Housing HTSL Generation",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "pages:dev": "wrangler pages dev dist",
    "pages:deploy": "npm run build && wrangler pages deploy dist",
    "db:init": "wrangler d1 execute housing-editor --file=schema.sql",
    "db:migrate": "wrangler d1 execute housing-editor --file=schema.sql",
    "db:backup": "wrangler d1 export housing-editor --output=backup.sql",
    "setup": "npm run db:init",
    "logs": "wrangler pages deployment tail"
  },
  "dependencies": {
    "axios": "^1.4.0",
    "crypto-browserify": "^3.12.1",
    "itty-router": "^5.0.23",
    "lodash": "^4.17.21",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.14.0",
    "react-syntax-highlighter": "^15.5.0",
    "reactflow": "^11.10.0",
    "uuid": "^13.0.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.14",
    "postcss": "^8.4.24",
    "tailwindcss": "^3.3.0",
    "vite": "^4.3.9"
  }
}
